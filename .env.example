# ─────────────────────────────────────────────
# REQUIRED — set these in Railway > Variables
# ─────────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_here
CHAT_ID_BULL=-100xxxxxxxxxx
CHAT_ID_BEAR=-100xxxxxxxxxx

# ─────────────────────────────────────────────
# OPTIONAL — tuning (defaults shown)
# ─────────────────────────────────────────────

# Binance Futures endpoint (change to testnet if needed)
BINANCE_BASE=https://fapi.binance.com

# How often the main loop wakes up (seconds)
SCAN_INTERVAL=60

# Parallel symbol requests per scan
CONCURRENCY=15

# Don't re-alert the same symbol+direction within this window (seconds)
ALERT_COOLDOWN=7200

# Minimum conviction score to fire an alert (0-23)
MIN_SCORE=18

# Seconds before 15m candle close to allow scanning (3 minutes = 180)
CANDLE_CLOSE_WINDOW=180

# Only scan the top N symbols by open interest (reduces noise + API calls)
TOP_N_SYMBOLS=80

# ─────────────────────────────────────────────
# SMC thresholds (advanced tuning)
# ─────────────────────────────────────────────
REJECTION_RATIO=1.5
MIN_BODY_RATIO=0.35
EXHAUSTION_VOL_MULT=2.5
PIVOT_DEPTH=5
